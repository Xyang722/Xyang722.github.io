---
import { PHOTOS_CONFIG, POSTS_CONFIG, SITE, SKILLSSHOWCASE_CONFIG, SOCIAL_LINKS } from '~/config.ts'
import Layout from '~/layouts/Layout.astro'
import SectionDivider from '~/components/base/SectionDivider.astro'
import SocialLink from '~/components/base/SocialLink.astro'
import List from '~/components/posts/card/List.astro'
import SkillsShowcase from '~/components/base/SkillsShowcase.astro'
import { getAllProjects, getNumPosts, getPinnedPosts } from '~/lib/data'
import { PhotosList } from '~/lib/photos'

const { size, type } = POSTS_CONFIG.homePageConfig
const { SKILLS_ENABLED, SKILLS_DATA } = SKILLSSHOWCASE_CONFIG

const pinnedPosts = await getPinnedPosts()
const hasPinnedPosts = pinnedPosts.length > 0
const showPosts = hasPinnedPosts ? pinnedPosts : await getNumPosts(size)
const projects = (await getAllProjects()).slice(0, 3)
const recentPhotos = PhotosList.slice(0, 3)

const focusItems = [
  {
    label: 'Notes',
    value: `${showPosts.length}+`,
    text: 'physics courses and reading records',
  },
  {
    label: 'Projects',
    value: `${projects.length}`,
    text: 'modeling and simulation traces',
  },
  {
    label: 'Photos',
    value: `${PhotosList.length}`,
    text: 'small moments from ordinary days',
  },
]
---

<Layout title="Home" description={SITE.description}>
  <div class="relative z-[1]">
    <section class="px-6 sm:px-8 py-12 sm:py-16">
      <div class="flex flex-col gap-8">
        <div class="space-y-6">
          <div class="inline-flex items-center gap-2 rounded-md border border-border/70 bg-accent/35 px-3 py-1 text-xs font-medium text-muted-foreground">
            <span class="size-1.5 rounded-full bg-primary/70"></span>
            Personal archive
          </div>
          <div class="space-y-4">
            <h1 class="text-5xl sm:text-6xl font-medium tracking-tight text-balance">rujin</h1>
            <p class="max-w-2xl text-xl sm:text-2xl leading-relaxed text-muted-foreground text-balance">
              Physics notes, research practice, and ordinary days.
            </p>
          </div>
          <div class="pro max-w-2xl text-muted-foreground text-pretty">
            <p>
              I keep this space for course notes, research reading, numerical experiments, and fragments of life. It is less a portfolio
              than a working desk: quiet, evolving, and close to what I am learning.
            </p>
          </div>
          {
            SOCIAL_LINKS.length > 0 && (
              <div class="flex flex-wrap gap-4 pt-1">
                {SOCIAL_LINKS.map((item) => (
                  <SocialLink href={item.url} icon={item.icon} aria-label={`Link of ${item.name}`} count={item.count} label="followers" />
                ))}
              </div>
            )
          }
        </div>

        <div class="grid grid-cols-1 sm:grid-cols-3 gap-3">
          {
            focusItems.map((item) => (
              <div class="rounded-md border border-border/70 bg-background/70 px-4 py-4">
                <div class="text-2xl font-medium tracking-tight">{item.value}</div>
                <div class="mt-1 text-sm font-medium text-foreground/80">{item.label}</div>
                <p class="mt-1 text-sm text-muted-foreground leading-5">{item.text}</p>
              </div>
            ))
          }
        </div>
      </div>
    </section>

    <SectionDivider />

    <section class="px-6 sm:px-8 py-10">
      <div class="mb-6 flex items-end justify-between gap-4">
        <div>
          <h2 class="text-2xl sm:text-3xl tracking-tight">Featured Notes</h2>
          <p class="text-muted-foreground mt-1">
            {hasPinnedPosts ? 'Pinned entries from the notebook.' : 'Recent entries from the notebook.'}
          </p>
        </div>
        <a href="/posts" class="hidden sm:inline-flex items-center gap-1.5 text-sm font-medium text-muted-foreground hover:text-foreground">
          All posts
          <span class="icon-[ph--arrow-right] size-4"></span>
        </a>
      </div>
      <List posts={showPosts} {type} coverLayout={POSTS_CONFIG.homePageConfig?.coverLayout} />
    </section>

    {
      projects.length > 0 && (
        <>
          <SectionDivider />
          <section class="px-6 sm:px-8 py-10">
            <div class="mb-6 flex items-end justify-between gap-4">
              <div>
                <h2 class="text-2xl sm:text-3xl tracking-tight">Research Practice</h2>
                <p class="text-muted-foreground mt-1">Small project records from modeling, simulation, and analysis.</p>
              </div>
              <a href="/projects" class="hidden sm:inline-flex items-center gap-1.5 text-sm font-medium text-muted-foreground hover:text-foreground">
                All projects
                <span class="icon-[ph--arrow-right] size-4"></span>
              </a>
            </div>
            <div class="grid grid-cols-1 gap-3">
              {projects.map((project) => (
                <a
                  href="/projects"
                  class="group rounded-md border border-border/70 bg-background/70 px-4 py-4 transition-colors hover:border-primary/30 hover:bg-accent/35"
                >
                  <div class="flex items-start justify-between gap-4">
                    <div>
                      <h3 class="font-medium text-foreground transition-colors group-hover:text-primary">{project.data.name}</h3>
                      <p class="mt-1 text-sm leading-6 text-muted-foreground">{project.data.description}</p>
                    </div>
                    <span class="icon-[ph--arrow-up-right] size-4 shrink-0 text-muted-foreground transition-colors group-hover:text-primary"></span>
                  </div>
                </a>
              ))}
            </div>
          </section>
        </>
      )
    }

    {
      recentPhotos.length > 0 && (
        <>
          <SectionDivider />
          <section class="px-6 sm:px-8 py-10">
            <div class="mb-6 flex items-end justify-between gap-4">
              <div>
                <h2 class="text-2xl sm:text-3xl tracking-tight">Life Timeline</h2>
                <p class="text-muted-foreground mt-1">{PHOTOS_CONFIG.description}</p>
              </div>
              <a href="/photos" class="hidden sm:inline-flex items-center gap-1.5 text-sm font-medium text-muted-foreground hover:text-foreground">
                All photos
                <span class="icon-[ph--arrow-right] size-4"></span>
              </a>
            </div>
            <div class="grid grid-cols-1 sm:grid-cols-3 gap-3">
              {recentPhotos.map((item) => (
                <a href="/photos" class="rounded-md border border-border/70 bg-background/70 px-4 py-4 transition-colors hover:border-primary/30 hover:bg-accent/35">
                  <div class="flex items-center justify-between gap-3">
                    <span class="text-sm font-medium text-muted-foreground">{item.date}</span>
                    <span class="text-lg leading-none">{item.icon.type === 'emoji' ? item.icon.value : ''}</span>
                  </div>
                  <h3 class="mt-3 text-sm font-semibold leading-5">{item.title}</h3>
                  {item.description && <p class="mt-1 text-sm leading-5 text-muted-foreground line-clamp-2">{item.description}</p>}
                </a>
              ))}
            </div>
          </section>
        </>
      )
    }

    {
      SKILLS_ENABLED && SKILLS_DATA.length > 0 && (
        <>
          <SectionDivider />
          <section class="py-10 pb-12 px-6 max-md:px-6">
            <div class="px-2 max-md:px-0">
              <h2 class="text-2xl sm:text-3xl tracking-tight">Tools & Interests</h2>
              <p class="text-muted-foreground mb-6 mt-1">Topics, methods, and tools that often appear in this archive.</p>
            </div>
            <SkillsShowcase skillsData={SKILLS_DATA} />
          </section>
        </>
      )
    }
  </div>
</Layout>
