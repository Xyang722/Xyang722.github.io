---
import Layout from '~/layouts/Layout.astro'

const title = 'Hobbies'
const description = 'Beyond physics — calligraphy and essay writing, where the brush meets the heart.'
---

<Layout {title} {description}>
  <div class="relative z-[1] py-10 pb-16 px-6 sm:px-8">
    <!-- Page header -->
    <div class="mb-10">
      <div class="inline-flex items-center gap-2 rounded-md border border-border/70 bg-accent/35 px-3 py-1 text-xs font-medium text-muted-foreground">
        <span class="size-1.5 rounded-full bg-primary/70"></span>
        Personal pursuits
      </div>
      <h1 class="mt-5 text-4xl sm:text-5xl font-medium tracking-tight text-balance">Hobbies</h1>
      <p class="mt-3 max-w-2xl text-xl leading-relaxed text-muted-foreground text-balance">
        Beyond physics — calligraphy and essay writing, where the brush meets the heart.
      </p>
    </div>

    <!-- Two hobby cards -->
    <div class="grid grid-cols-1 sm:grid-cols-2 gap-6 sm:gap-8">
      <!-- Calligraphy Card -->
      <a
        href="/hobbies/calligraphy"
        class="group relative block overflow-hidden rounded-xl border border-border/70 bg-background/60 transition-all duration-500 hover:shadow-lg hover:border-primary/30"
      >
        <!-- Background decoration -->
        <div class="absolute inset-0 bg-gradient-to-br from-amber-50/40 via-transparent to-transparent dark:from-amber-900/10 opacity-0 group-hover:opacity-100 transition-opacity duration-500"></div>

        <div class="relative p-8 sm:p-10 flex flex-col items-center text-center min-h-[320px] justify-center">
          <!-- Icon -->
          <div class="mb-6 size-20 rounded-full border border-border/60 bg-accent/25 flex items-center justify-center text-4xl transition-transform duration-500 group-hover:scale-110 group-hover:border-primary/40">
            ✒️
          </div>

          <!-- Title -->
          <h2 class="text-2xl sm:text-3xl font-semibold tracking-tight text-foreground transition-colors duration-300 group-hover:text-primary">
            Calligraphy
          </h2>

          <!-- Hidden description — revealed on hover -->
          <div class="mt-3 max-w-xs overflow-hidden transition-all duration-500 max-h-0 opacity-0 group-hover:max-h-40 group-hover:opacity-100">
            <p class="text-sm leading-6 text-muted-foreground">
              The art of the brush — inspired by classical masters and the quiet rhythm of ink on paper.
            </p>
          </div>

          <!-- Arrow hint -->
          <div class="mt-6 transition-all duration-500 transform group-hover:translate-y-1">
            <span class="inline-flex items-center gap-1.5 text-xs font-medium text-muted-foreground group-hover:text-primary transition-colors duration-300">
              Explore
              <span class="icon-[ph--arrow-right] size-3.5 transition-transform duration-300 group-hover:translate-x-0.5"></span>
            </span>
          </div>
        </div>
      </a>

      <!-- Essay Card -->
      <a
        href="/hobbies/essay"
        class="group relative block overflow-hidden rounded-xl border border-border/70 bg-background/60 transition-all duration-500 hover:shadow-lg hover:border-primary/30"
      >
        <!-- Background decoration -->
        <div class="absolute inset-0 bg-gradient-to-br from-sky-50/40 via-transparent to-transparent dark:from-sky-900/10 opacity-0 group-hover:opacity-100 transition-opacity duration-500"></div>

        <div class="relative p-8 sm:p-10 flex flex-col items-center text-center min-h-[320px] justify-center">
          <!-- Icon -->
          <div class="mb-6 size-20 rounded-full border border-border/60 bg-accent/25 flex items-center justify-center text-4xl transition-transform duration-500 group-hover:scale-110 group-hover:border-primary/40">
            📝
          </div>

          <!-- Title -->
          <h2 class="text-2xl sm:text-3xl font-semibold tracking-tight text-foreground transition-colors duration-300 group-hover:text-primary">
            Essay
          </h2>

          <!-- Hidden description — revealed on hover -->
          <div class="mt-3 max-w-xs overflow-hidden transition-all duration-500 max-h-0 opacity-0 group-hover:max-h-40 group-hover:opacity-100">
            <p class="text-sm leading-6 text-muted-foreground">
              Writing down what I see and feel — a warm process of capturing everyday moments.
            </p>
          </div>

          <!-- Arrow hint -->
          <div class="mt-6 transition-all duration-500 transform group-hover:translate-y-1">
            <span class="inline-flex items-center gap-1.5 text-xs font-medium text-muted-foreground group-hover:text-primary transition-colors duration-300">
              Explore
              <span class="icon-[ph--arrow-right] size-3.5 transition-transform duration-300 group-hover:translate-x-0.5"></span>
            </span>
          </div>
        </div>
      </a>
    </div>
  </div>
</Layout>
