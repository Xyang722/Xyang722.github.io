---
import Layout from '~/layouts/Layout.astro'
import PhotoTimeline from '~/components/photos/PhotoTimeline.astro'
import { CalligraphyList } from '~/lib/calligraphy'

const title = 'Calligraphy'
const description = 'A personal collection of calligraphy works and practice, inspired by classical Chinese calligraphy.'
---

<Layout {title} {description} disableViewTransition>
  <div class="relative z-[1] py-8 pb-10 px-6 sm:px-8">
    <h1 class="tracking-tight text-4xl sm:text-5xl text-foreground pb-1.5">
      {title}
    </h1>
    <div class="pro max-w-2xl text-muted-foreground">
      <p class="mt-2" set:html={'There is something in the calligraphy of Wen Zhengming (文徵明) — wind dancing with jade flowers, a spring named Bamboo Valley (<em>风舞琼花，泉名竹涧</em>). Utterly intoxicating.'}></p>
    </div>

    <div class="mt-12">
      {
        CalligraphyList.length > 0 ? (
          <PhotoTimeline photoData={CalligraphyList} />
        ) : (
          <div class="text-muted-foreground mb-4">
            <p class="text-sm">No calligraphy works yet — check back soon.</p>
          </div>
        )
      }
    </div>
  </div>
</Layout>
